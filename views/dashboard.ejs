                        <p class="er25dash-status-desc" id="dash-whatsapp-status-desc">Aguardando leitura.</p>
                    </div>
                    <span class="er25dash-pill er25dash-pill-warn" id="dash-whatsapp-status-pill">Verificando</span>
                </div>

                <div class="er25dash-status-row">
